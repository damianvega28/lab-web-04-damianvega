<h1>Pets</h1>

<div class="container mt-4">
  <h1>Pets</h1>
  
  <table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Species</th>
        <th>Breed</th>
        <th>Owner Name</th>
        <th>Date of Birth</th>
      </tr>
    </thead>
    <tbody>
      <% @pets.each do |pet| %>
        <tr>
          <td><%= link_to pet.name, pet_path(pet), class: "text-decoration-none fw-bold" %></td>
          <td><%= pet.species %></td>
          <td><%= pet.breed %></td>
          <td><%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}", owner_path(pet.owner), class: "text-decoration-none" %></td>
          <td><%= pet.date_of_birth&.strftime("%B %d, %Y") %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>