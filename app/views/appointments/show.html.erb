<h1>Appointments</h1>

<div class="container mt-4">
  <h1>Appointment Details</h1>
  
  <div class="card mb-4 shadow-sm">
    <div class="card-body">
      <h4 class="card-title"><%= @appointment.date&.strftime("%B %d, %Y - %H:%M") %></h4>
      <p class="card-text"><strong>Status:</strong> <span class="badge bg-primary"><%= @appointment.status.to_s.titleize %></span></p>
      <p class="card-text"><strong>Reason:</strong> <%= @appointment.reason %></p>
      <p class="card-text"><strong>Pet:</strong> <%= link_to @appointment.pet.name, pet_path(@appointment.pet), class: "text-decoration-none" %></p>
      <p class="card-text"><strong>Veterinarian:</strong> <%= link_to "Dr. #{@appointment.vet.last_name}", vet_path(@appointment.vet), class: "text-decoration-none" %></p>
    </div>
  </div>

  <h3>Treatments</h3>
  <% if @appointment.treatments.any? %>
    <table class="table table-bordered mt-3">
      <thead class="table-light">
        <tr>
          <th>Name</th>
          <th>Medication</th>
          <th>Dosage</th>
          <th>Administered At</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% @appointment.treatments.each do |treatment| %>
          <tr>
            <td><%= treatment.name %></td>
            <td><%= treatment.medication %></td>
            <td><%= treatment.dosage %></td>
            <td><%= treatment.administered_at&.strftime("%B %d, %Y - %H:%M") %></td>
            <td><%= treatment.notes %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">No treatments recorded for this appointment yet.</p>
  <% end %>

  <br>
  <%= link_to "Back to Appointments", appointments_path, class: "btn btn-secondary" %>
</div>