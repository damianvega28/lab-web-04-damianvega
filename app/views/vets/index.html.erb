<h1>Vets</h1>

<div class="container mt-4">
  <h1>Veterinarians</h1>
  
  <table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
      <tr>
        <th>Full Name</th>
        <th>Email</th>
        <th>Specialization</th>
      </tr>
    </thead>
    <tbody>
      <% @vets.each do |vet| %>
        <tr>
          <td><%= link_to "#{vet.first_name} #{vet.last_name}", vet_path(vet), class: "text-decoration-none fw-bold" %></td>
          <td><%= vet.email %></td>
          <td><%= vet.specialization %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>