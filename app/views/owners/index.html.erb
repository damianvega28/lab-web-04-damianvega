<h1>Owners</h1>

<div class="container mt-4">
  <h1>Owners</h1>
  
  <table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
      <tr>
        <th>Full Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Number of Pets</th>
      </tr>
    </thead>
    <tbody>
      <% @owners.each do |owner| %>
        <tr>
          <td><%= link_to "#{owner.first_name} #{owner.last_name}", owner_path(owner), class: "text-decoration-none fw-bold" %></td>
          <td><%= owner.email %></td>
          <td><%= owner.phone %></td>
          <td><%= owner.pets.count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>